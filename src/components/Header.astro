---
const navItems = [
    { linkText: 'Hem', href: '/' },
    { linkText: 'Tjänster', href: '#tjanster' },
    { linkText: 'Om mig', href: '#om-mig' },
    { linkText: 'Kontakt', href: '#kontakt' }
];
---

<nav class="flex flex-wrap items-center justify-center pt-6 pb-6 sm:pt-10">
    {
        !!navItems?.length && (
            <ul class="flex flex-wrap justify-center gap-x-4 gap-y-1">
                {navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class="inline-block px-1.5 py-1 font-medium no-underline hover:text-primary sm:px-3 sm:py-2"
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))}
            </ul>
        )
    }
</nav>
