---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import neck from '../assets/neck.jpg';
import neckGif from '../assets/neckGif.gif';

const services = [
    { title: 'Nack Release 15 min',info: `Terapeutisk massage med fokus på att släppa spänningar i nacken. Vi jobbar med massage, triggerpunkter och stretching.`, img: neck,img2: neckGif, href: 'https://www.bokadirekt.se/boka-tjanst/neoskin-39252/nacke-release-3413961' },
    { title: 'Klassisk Massage 25 min',info: `Klassisk massage med fokus på t.ex nacke eller ländrygg.`, img: neck,img2: neckGif, href: 'https://www.bokadirekt.se/boka-tjanst/neoskin-39252/klassisk-massage-fokus-3347908' },
    { title: 'Klassisk Massage 50 min',info: `Klassisk massage, skräddarsys efter önskemål.`, img: neck,img2: neckGif, href: 'https://www.bokadirekt.se/boka-tjanst/neoskin-39252/klassisk-massage-lyx-3347909' },
    { title: 'Klassisk Massage 75 min',info: `Klassisk helkroppsmassage som skräddarsys efter önskemål.`, img: neck,img2: neckGif, href: 'https://www.bokadirekt.se/boka-tjanst/neoskin-39252/klassisk-massage-extra-lang-3347907' },
];
---

 <div class="space-y-6">
  <ul class="grid md:grid-cols-2 gap-5 md:gap-6">
    {
      services.map((service) => (
        <li class="list-none">
            <a href={service.href} class="
            relative
            group
            bg-white/20 backdrop-blur-sm
            rounded-xl overflow-hidden
            border border-white/10
            flex flex-col
            items-stretch
            h-60 md:h-75
            no-underline
          ">
            <!-- Image -->
            <div>
                <Image
                  src={service.img}
                  alt="BjönMassage"
                  width={320}
                  height={240}
                  layout="constrained"   
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-500 ease-in-out group-hover:opacity-0"
                  />
                    <Image
                  src={service.img2}
                  alt="Hover view"
                  width={320}
                  height={240}
                  layout="constrained"  
                  class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 ease-in-out group-hover:opacity-100"
                  />
            </div>
            <!-- Content -->
            <div class="flex-1 p-5 md:p-6 flex flex-col gap-3 md:gap-4 z-10 bg-[#ffefd4cc] text-black ">
              <h3 class="text-xl md:text-3xl font-medium opacity-90">
                {service.title}
              </h3>

              <p class="text-base md:text-xl leading-relaxed opacity-90 flex-1">
                {service.info}
              </p>

              <!-- Booking button/link area -->
              <div class="mt-2 md:mt-4">
                <div
                  class="
                    absolute bottom-2 right-2
                    inline-flex items-center gap-2.5
                    px-2 py-1 md:px-2 md:py-1
                    border border-black/10
                    rounded-lg
                    text-black font-medium
                    transition-colors
                    no-underline
                  "
                >
                  <span class="text-lg md:text-xl">Boka</span>
                   <Image
                    src={logo}
                    width={36}
                    height={36}
                    alt=""
                    class="w-8 md:w-9 h-8 md:h-9 object-contain"
                  />
                </div>
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</div>
 
 
 
